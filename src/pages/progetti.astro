---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Progetti">

  <section class="py-12">

    <h1 class="text-4xl font-bold mb-8">
      I miei progetti
    </h1>


    <div class="grid md:grid-cols-2 gap-6">


      <article class="border rounded-xl p-6 hover:shadow-lg transition">

        <h2 class="text-xl font-bold mb-3">
          Portfolio personale
        </h2>

        <p class="text-gray-600 mb-4">
          Sito web realizzato con Astro, TypeScript e Tailwind CSS.
        </p>

        <span class="text-sm text-gray-500">
          Astro · Tailwind · TypeScript
        </span>

      </article>



      <article class="border rounded-xl p-6 hover:shadow-lg transition">

        <h2 class="text-xl font-bold mb-3">
          Secondo progetto
        </h2>

        <p class="text-gray-600 mb-4">
          Descrizione del mio progetto futuro.
        </p>

        <span class="text-sm text-gray-500">
          JavaScript · API
        </span>

      </article>


    </div>

  </section>

</Layout>