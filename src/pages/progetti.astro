---
import Layout from '../layouts/Layout.astro'

const progetti = [
  {
    titolo: "Portfolio personale",
    desc: "Il sito che stai guardando. Progettato e costruito da zero con Astro, Tailwind CSS e TypeScript. Primo progetto concreto del mio percorso nel web design.",
    tag: ["Astro", "Tailwind", "TypeScript"],
    link: "https://github.com/olgamarrazzo",
    attuale: true,
    img: "/portfolio-preview.png",
  },
  {
    titolo: "Progetto 02",
    desc: "In arrivo. Sto lavorando a nuovi progetti durante il corso.",
    tag: [],
    link: null,
    attuale: false,
    img: null,
  },
  {
    titolo: "Progetto 03",
    desc: "In arrivo. Sto lavorando a nuovi progetti durante il corso.",
    tag: [],
    link: null,
    attuale: false,
    img: null,
  },
]
---

<Layout title="Progetti — Olga Marrazzo" description="Progetti realizzati da Olga Marrazzo: siti web, interfacce e design con Astro, Tailwind CSS e TypeScript.">

<!-- Noise -->
<div class="noise-page"></div>

<!-- Sfondo con glow -->
<div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
  <div class="absolute -top-40 -right-40 w-[500px] h-[500px] rounded-full bg-cyan-500/[0.04] blur-3xl"></div>
  <div class="absolute bottom-0 -left-40 w-[400px] h-[400px] rounded-full bg-purple-500/[0.04] blur-3xl"></div>
</div>

<section class="relative z-10 pt-32 pb-24 md:pt-40 md:pb-32 max-w-6xl mx-auto px-6">

  <!-- Header -->
  <div class="rv mb-14">
    <span class="section-label">Lavori</span>
    <h1 class="section-title">I miei progetti</h1>
    <p class="mt-5 text-base text-white/60 max-w-xl leading-relaxed">
      Sto costruendo il portfolio progetto per progetto. Torna presto per vedere i nuovi lavori.
    </p>
  </div>

  <!-- Grid progetti -->
  <div class="grid md:grid-cols-2 gap-6">

            {progetti.map((p, i) => (

      <article
        class:list={[
          "gc rv flex flex-col justify-between gap-0 overflow-hidden group",
          !p.attuale && "opacity-60",
          !p.img && "pointer-events-none",
        ]}
        style={`transition-delay: ${0.1 + i * 0.1}s`}
      >

        {p.img ? (
          <div class="overflow-hidden bg-[#080414]">
            <img
              src={p.img}
              alt={`Screenshot di ${p.titolo}`}
              class="w-full h-auto object-contain transition-transform duration-700 ease-out group-hover:scale-105"
              loading="lazy"
            />
          </div>
        ) : (
          <div class="placeholder-progetto">
            <div class="placeholder-bordo"></div>
            <div class="placeholder-icona">
              <iconify-icon icon="lucide:hammer" width="28" aria-hidden="true"></iconify-icon>
            </div>
            <span class="placeholder-testo">In lavorazione</span>
          </div>
        )}

        <div class="p-8 flex flex-col justify-between gap-6 flex-1">
          <div>
            <div class="flex justify-between items-start mb-4 gap-4">
              <h2 class="text-lg font-medium tracking-tight text-white">
                {p.titolo}
              </h2>
              {p.attuale ? (
                <span class="tag-attuale shrink-0">Attuale</span>
              ) : (
                <span class="tag-soon shrink-0">Coming soon</span>
              )}
            </div>
            <p class="text-[14px] text-white/45 leading-relaxed">
              {p.desc}
            </p>
          </div>

          <div class="flex justify-between items-center flex-wrap gap-3">
            <div class="flex flex-wrap gap-2">
              {p.tag.map((t) => (
                <span class="tech-tag-sm">{t}</span>
              ))}
            </div>
            {p.link && (
              <a
                href={p.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-cyan-400 text-sm font-medium hover:gap-2.5 transition-all duration-300"
              >
                GitHub
                <iconify-icon icon="lucide:arrow-up-right" width="15" aria-hidden="true"></iconify-icon>
              </a>
            )}
          </div>
        </div>

      </article>

    ))}

  </div>

  <!-- CTA bottom -->
  <div class="rv mt-16 text-center" style="transition-delay: 0.4s;">
    <p class="text-sm text-white/30 mb-6">Vuoi collaborare a un progetto?</p>
    <a href="/contatti" class="btn-primary">
      <iconify-icon icon="lucide:send" width="16" class="mr-1.5" aria-hidden="true"></iconify-icon>
      Scrivimi
    </a>
  </div>

</section>

</Layout>