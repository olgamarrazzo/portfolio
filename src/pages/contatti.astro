---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Contatti — Olga Marrazzo">

  <section class="pt-32 pb-20 max-w-7xl mx-auto px-6">

    <p class="text-sm font-medium tracking-widest text-cyan-700 uppercase mb-3">
      Contatti
    </p>

    <h1 class="text-4xl font-semibold text-sky-950 mb-4">
      Parliamo insieme
    </h1>

    <p class="text-lg text-slate-600 mb-12 max-w-xl">
      Hai un progetto, una domanda o vuoi semplicemente connetterti? Rispondo di solito entro 24 ore.
    </p>


    <div class="flex gap-6 mb-10">

      <a
        href="https://www.linkedin.com/in/olga-marrazzo-5808402a5"
        target="_blank"
        rel="noopener noreferrer"
        class="
        text-sm
        text-slate-600
        hover:text-cyan-700
        transition
        "
      >
        LinkedIn →
      </a>


      <a
        href="https://github.com/olgamarrazzo"
        target="_blank"
        rel="noopener noreferrer"
        class="
        text-sm
        text-slate-600
        hover:text-cyan-700
        transition
        "
      >
        GitHub →
      </a>

    </div>


    <form
      id="contact-form"
      class="
      flex
      flex-col
      gap-4
      max-w-2xl
      "
    >

      <input
        id="nome"
        name="nome"
        type="text"
        placeholder="Nome"
        required
        class="
        border
        border-slate-200
        rounded-2xl
        px-4
        py-3
        text-sm
        text-slate-900
        placeholder:text-slate-400
        focus:outline-none
        focus:border-cyan-700
        transition
        "
      />


      <input
        id="email"
        name="email"
        type="email"
        placeholder="Email"
        required
        class="
        border
        border-slate-200
        rounded-2xl
        px-4
        py-3
        text-sm
        text-slate-900
        placeholder:text-slate-400
        focus:outline-none
        focus:border-cyan-700
        transition
        "
      />


      <textarea
        id="messaggio"
        name="messaggio"
        rows="5"
        placeholder="Messaggio"
        required
        class="
        border
        border-slate-200
        rounded-2xl
        px-4
        py-3
        text-sm
        text-slate-900
        placeholder:text-slate-400
        focus:outline-none
        focus:border-cyan-700
        transition
        "
      ></textarea>


      <button
        type="submit"
        class="
        bg-cyan-700
        text-white
        py-3
        rounded-full
        text-sm
        font-medium
        hover:bg-cyan-800
        transition
        "
      >
        Invia messaggio
      </button>


      <p id="status" class="text-sm text-center hidden"></p>


    </form>


  </section>


<script>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('status');

  if (!form) {
    throw new Error('Form non trovato');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const button = form.querySelector('button');

    button.disabled = true;
    button.textContent = 'Invio...';

    const data = Object.fromEntries(new FormData(form));

    const response = await fetch('/api/contatto', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(data)
    });

    if (response.ok) {
      form.reset();
      status.textContent = 'Messaggio inviato. Ti rispondo presto!';
      status.className = 'text-sm text-center text-green-600';
    } else {
      status.textContent = 'Errore durante l invio. Riprova.';
      status.className = 'text-sm text-center text-red-600';
      button.disabled = false;
      button.textContent = 'Invia messaggio';
    }

    status.classList.remove('hidden');
  });
</script>

</Layout>