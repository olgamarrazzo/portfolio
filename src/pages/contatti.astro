---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Contatti — Olga Marrazzo" description="Contatta Olga Marrazzo per collaborazioni, progetti o domande. Risponde entro 24 ore.">

<section class="relative z-10 pt-32 pb-24 md:pt-40 md:pb-32 max-w-5xl mx-auto px-6">

  <div class="rv mb-14">
    <span class="section-label">Contatti</span>
    <h1 class="section-title">Parliamo insieme</h1>
    <p class="mt-5 text-sm text-white max-w-xl leading-relaxed">
      Hai un progetto, una domanda o vuoi semplicemente connetterti? Rispondo di solito entro 24 ore.
    </p>
  </div>

  <div class="grid md:grid-cols-5 gap-8">
    <!-- Form -->
    <div class="md:col-span-3 rv" style="transition-delay: 0.08s;">
      <form id="contact-form" class="flex flex-col gap-4" novalidate>
        <div>
          <label for="nome" class="form-label">Nome</label>
          <input id="nome" name="nome" type="text" placeholder="Il tuo nome" required class="fi" autocomplete="name" />
        </div>
        <div>
          <label for="email" class="form-label">Email</label>
          <input id="email" name="email" type="email" placeholder="la-tua@email.com" required class="fi" autocomplete="email" />
        </div>
        <div>
          <label for="messaggio" class="form-label">Messaggio</label>
          <textarea id="messaggio" name="messaggio" rows="5" placeholder="Raccontami del tuo progetto..." required class="fi" style="resize: none;"></textarea>
        </div>
        <button type="submit" class="btn-primary w-full md:w-auto" id="subBtn">Invia messaggio</button>
        <p id="status" class="text-sm text-center hidden" aria-live="polite"></p>
      </form>
    </div>

<!-- Info -->
    <div class="md:col-span-2 rv" style="transition-delay: 0.18s;">
      <div class="gc contact-info-card p-7 h-full flex flex-col justify-between">
        <div>
          <h3 class="text-base font-medium tracking-tight text-[#0a0618] mb-6">Info</h3>
          <div class="space-y-5">
            <div class="flex items-start gap-3">
              <iconify-icon icon="lucide:mail" width="16" class="text-cyan-600 mt-0.5 shrink-0" aria-hidden="true"></iconify-icon>
              <div>
                <p class="text-[11px] text-[#0a0618]/45 mb-0.5">Email</p>
                <a href="mailto:olgamarrazzoit@gmail.com" class="text-sm text-[#0a0618]/75 hover:text-cyan-600 transition-colors duration-300">olgamarrazzoit@gmail.com</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <iconify-icon icon="lucide:map-pin" width="16" class="text-cyan-600 mt-0.5 shrink-0" aria-hidden="true"></iconify-icon>
              <div>
                <p class="text-[11px] text-[#0a0618]/45 mb-0.5">Posizione</p>
                <p class="text-sm text-[#0a0618]/75">Italia</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <iconify-icon icon="lucide:briefcase" width="16" class="text-cyan-600 mt-0.5 shrink-0" aria-hidden="true"></iconify-icon>
              <div>
                <p class="text-[11px] text-[#0a0618]/45 mb-0.5">Disponibilit&agrave;</p>
                <p class="text-sm text-[#0a0618]/75">Disponibile per collaborazioni e progetti</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <iconify-icon icon="lucide:clock" width="16" class="text-cyan-600 mt-0.5 shrink-0" aria-hidden="true"></iconify-icon>
              <div>
                <p class="text-[11px] text-[#0a0618]/45 mb-0.5">Risposta</p>
                <p class="text-sm text-[#0a0618]/75">Entro 24 ore</p>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-8 pt-5 border-t border-[#0a0618]/10">
          <p class="text-[11px] text-[#0a0618]/35 mb-3.5">Social</p>
          <div class="flex gap-4">
            <a href="https://www.linkedin.com/in/olga-marrazzo-5808402a5" target="_blank" rel="noopener noreferrer" aria-label="Profilo LinkedIn" class="soc-icon text-[#0a0618]/40 text-[19px] hover:text-cyan-600">
              <iconify-icon icon="mdi:linkedin" aria-hidden="true"></iconify-icon>
            </a>
            <a href="https://github.com/olgamarrazzo" target="_blank" rel="noopener noreferrer" aria-label="Profilo GitHub" class="soc-icon text-[#0a0618]/40 text-[19px] hover:text-cyan-600">
              <iconify-icon icon="mdi:github" aria-hidden="true"></iconify-icon>
            </a>
          </div>
        </div>
      </div>
    </div>
</div>
</section>

</Layout>
<style>
  .form-label {
  display: block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgb(5, 5, 42);
  text-shadow: 0 1px 1px rgba(255, 255, 255, 0.4);
  margin-bottom: 0.5rem;
}

  /* Override mirato solo per il riquadro Info di questa pagina */
  .contact-info-card {
    background: rgba(255, 255, 255, 0.70);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-color: rgba(255, 255, 255, 0.5);
  }
  .contact-info-card:hover {
    background: rgba(255, 255, 255, 0.78);
    border-color: rgba(255, 255, 255, 0.6);
  }

  /* Titolo pagina: stesso font e peso dell'hero name in index.astro */
  section.relative.z-10 > .rv > .section-title {
    font-family: 'Playfair Display', serif;
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1.05;
  }
</style>

<script>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('status');
  const subBtn = document.getElementById('subBtn');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      subBtn.disabled = true;
      subBtn.textContent = 'Invio in corso\u2026';
      const data = Object.fromEntries(new FormData(form));
      try {
        const response = await fetch('/api/contatto', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (response.ok) {
          form.reset();
          status.textContent = 'Messaggio inviato! Ti rispondo presto.';
          status.className = 'form-ok text-sm text-center';
          subBtn.textContent = 'Inviato \u2713';
          subBtn.style.background = 'linear-gradient(to right, rgb(103 232 249), rgb(217 70 239))';
        } else {
          status.textContent = 'Errore durante l\'invio. Riprova.';
          status.className = 'form-err text-sm text-center';
          subBtn.disabled = false;
          subBtn.textContent = 'Invia messaggio';
        }
      } catch {
        status.textContent = 'Errore di connessione. Riprova.';
        status.className = 'form-err text-sm text-center';
        subBtn.disabled = false;
        subBtn.textContent = 'Invia messaggio';
      }
      status.classList.remove('hidden');
    });
  }

  
</script>