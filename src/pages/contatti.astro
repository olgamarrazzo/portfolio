---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Contatti — Olga Marrazzo">

<div class="noise-page"></div>

<div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
  <div class="absolute -top-40 -left-40 w-[500px] h-[500px] rounded-full bg-purple-500/[0.04] blur-3xl"></div>
  <div class="absolute bottom-0 -right-40 w-[400px] h-[400px] rounded-full bg-cyan-500/[0.04] blur-3xl"></div>
</div>

<section class="relative z-10 pt-32 pb-24 md:pt-40 md:pb-32 max-w-5xl mx-auto px-6">

  <div class="rv mb-14">
    <span class="section-label">Get in touch</span>
    <h1 class="section-title">Parliamo insieme</h1>
    <p class="mt-5 text-base text-white/45 max-w-xl leading-relaxed">
      Hai un progetto, una domanda o vuoi semplicemente connetterti? Rispondo di solito entro 24 ore.
    </p>
  </div>

  <div class="grid md:grid-cols-5 gap-8">

    <div class="md:col-span-3 rv" style="transition-delay: 0.08s;">
      <form id="contact-form" class="flex flex-col gap-4.5">
        <div>
          <label class="block text-[11px] font-medium tracking-[0.14em] uppercase text-white/35 mb-2">Nome</label>
          <input id="nome" name="nome" type="text" placeholder="Il tuo nome" required class="fi" />
        </div>
        <div>
          <label class="block text-[11px] font-medium tracking-[0.14em] uppercase text-white/35 mb-2">Email</label>
          <input id="email" name="email" type="email" placeholder="la-tua@email.com" required class="fi" />
        </div>
        <div>
          <label class="block text-[11px] font-medium tracking-[0.14em] uppercase text-white/35 mb-2">Messaggio</label>
          <textarea id="messaggio" name="messaggio" rows="5" placeholder="Raccontami del tuo progetto..." required class="fi" style="resize: none;"></textarea>
        </div>
        <button type="submit" class="btn-primary w-full md:w-auto" id="subBtn">Invia messaggio</button>
        <p id="status" class="text-sm text-center hidden"></p>
      </form>
    </div>

    <div class="md:col-span-2 rv" style="transition-delay: 0.18s;">
      <div class="gc p-7 h-full flex flex-col justify-between">
        <div>
          <h3 class="text-lg font-medium tracking-tight text-white mb-6">Info</h3>
          <div class="space-y-5">
            <div class="flex items-start gap-3">
              <iconify-icon icon="lucide:mail" width="17" class="text-cyan-400 mt-0.5 shrink-0"></iconify-icon>
              <div>
                <p class="text-[11px] text-white/35 mb-0.5">Email</p>
                <a href="mailto:olgamarrazzoit@gmail.com" class="text-sm text-white/75 hover:text-cyan-400 transition-colors duration-300">olgamarrazzoit@gmail.com</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <iconify-icon icon="lucide:map-pin" width="17" class="text-cyan-400 mt-0.5 shrink-0"></iconify-icon>
              <div>
                <p class="text-[11px] text-white/35 mb-0.5">Posizione</p>
                <p class="text-sm text-white/75">Italia</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <iconify-icon icon="lucide:briefcase" width="17" class="text-cyan-400 mt-0.5 shrink-0"></iconify-icon>
              <div>
                <p class="text-[11px] text-white/35 mb-0.5">Disponibilità</p>
                <p class="text-sm text-white/75">Disponibile per collaborazioni e progetti</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <iconify-icon icon="lucide:clock" width="17" class="text-cyan-400 mt-0.5 shrink-0"></iconify-icon>
              <div>
                <p class="text-[11px] text-white/35 mb-0.5">Risposta</p>
                <p class="text-sm text-white/75">Entro 24 ore</p>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-8 pt-5 border-t border-white/5">
          <p class="text-[11px] text-white/25 mb-3.5">Social</p>
          <div class="flex gap-4">
            <a href="https://www.linkedin.com/in/olga-marrazzo-5808402a5" target="_blank" rel="noopener noreferrer" class="soc-icon text-white/35 text-[19px] hover:text-cyan-400">
              <iconify-icon icon="mdi:linkedin"></iconify-icon>
            </a>
            <a href="https://github.com/olgamarrazzo" target="_blank" rel="noopener noreferrer" class="soc-icon text-white/35 text-[19px] hover:text-cyan-400">
              <iconify-icon icon="mdi:github"></iconify-icon>
            </a>
          </div>
        </div>
      </div>
    </div>

  </div>

</section>

</Layout>

<script>
  const rvObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add('vis');
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -30px 0px' }
  );
  document.querySelectorAll('.rv').forEach((el) => rvObs.observe(el));

  const form = document.getElementById('contact-form');
  const status = document.getElementById('status');
  const subBtn = document.getElementById('subBtn');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      subBtn.disabled = true;
      subBtn.textContent = 'Invio in corso…';
      const data = Object.fromEntries(new FormData(form));
      try {
        const response = await fetch('/api/contatto', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (response.ok) {
          form.reset();
          status.textContent = 'Messaggio inviato! Ti rispondo presto.';
          status.className = 'form-ok text-sm text-center';
          subBtn.textContent = 'Inviato ✓';
        } else {
          status.textContent = 'Errore durante l\'invio. Riprova.';
          status.className = 'form-err text-sm text-center';
          subBtn.disabled = false;
          subBtn.textContent = 'Invia messaggio';
        }
      } catch {
        status.textContent = 'Errore di connessione. Riprova.';
        status.className = 'form-err text-sm text-center';
        subBtn.disabled = false;
        subBtn.textContent = 'Invia messaggio';
      }
      status.classList.remove('hidden');
    });
  }
</script>