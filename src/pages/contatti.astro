---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Contatti">

  <section class="py-12 max-w-xl">

    <h1 class="text-4xl font-bold mb-6">
      Scrivimi
    </h1>

    <p class="text-gray-600 mb-8">
      Rispondo di solito entro 24 ore.
    </p>


    <form id="contact-form" class="flex flex-col gap-4">

      <input
        id="nome"
        name="nome"
        type="text"
        placeholder="Nome"
        required
        class="border rounded-lg px-4 py-3"
      />


      <input
        id="email"
        name="email"
        type="email"
        placeholder="Email"
        required
        class="border rounded-lg px-4 py-3"
      />


      <textarea
        id="messaggio"
        name="messaggio"
        rows="5"
        placeholder="Messaggio"
        required
        class="border rounded-lg px-4 py-3"
      ></textarea>


      <button
        type="submit"
        class="bg-black text-white py-3 rounded-lg hover:bg-gray-800 transition"
      >
        Invia messaggio
      </button>


      <p id="status" class="text-sm text-center hidden"></p>

    </form>


  </section>

<script>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('status');

  if (!form) {
    throw new Error('Form non trovato');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const button = form.querySelector('button');

    button.disabled = true;
    button.textContent = 'Invio...';

    const data = Object.fromEntries(new FormData(form));

    console.log('DATI FORM:', data);

    const response = await fetch('/api/contatto', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(data)
    });

    console.log('STATUS:', response.status);

    if (response.ok) {
      form.reset();

      status.textContent = 'Messaggio inviato. Ti risponderò presto!';
      status.className = 'text-sm text-center text-green-600';
    } else {
      status.textContent = 'Errore durante l’invio. Riprova.';
      status.className = 'text-sm text-center text-red-600';

      button.disabled = false;
      button.textContent = 'Invia messaggio';
    }

    status.classList.remove('hidden');
  });
</script>

</Layout>