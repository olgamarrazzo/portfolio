---
import Layout from '../layouts/Layout.astro'

const skills = [
  {
    titolo: "HTML & Tailwind CSS",
    desc: "Markup semantico, layout utility-first con Grid e Flexbox, classi responsive.",
    icona: "lucide:code-2",
    livello: 88,
    color: "cyan",
  },
  {
    titolo: "Astro",
    desc: "Routing basato su file, composizione componenti con slot, dati dinamici nel frontmatter.",
    icona: "lucide:rocket",
    livello: 80,
    color: "purple",
  },
  {
    titolo: "JavaScript",
    desc: "Sintassi ES6+, Fetch API, IntersectionObserver, manipolazione DOM e gestione eventi.",
    icona: "lucide:braces",
    livello: 82,
    color: "cyan",
  },
  {
    titolo: "Animazioni CSS",
    desc: "Keyframe personalizzati, reveal allo scroll, effetto parallax, glassmorphism.",
    icona: "lucide:sparkles",
    livello: 85,
    color: "purple",
  },
  {
    titolo: "UI Design & Figma",
    desc: "Prototipazione ad alta fedeltà, creazione design system, gerarchia visiva e specifiche componente.",
    icona: "lucide:layout",
    livello: 78,
    color: "cyan",
  },
  {
    titolo: "Integrazione API",
    desc: "Comunicazione client-server con Fetch, gestione form data, servizio email Resend.",
    icona: "lucide:plug",
    livello: 75,
    color: "purple",
  },
  {
    titolo: "Responsive Design",
    desc: "Approccio mobile-first, media queries CSS, breakpoint Tailwind, layout adattivi.",
    icona: "lucide:smartphone",
    livello: 85,
    color: "cyan",
  },
  {
    titolo: "UI / UX Design",
    desc: "Design system coerente tra pagine, estetica dark cinematografica, interazioni fluide.",
    icona: "lucide:pen-tool",
    livello: 78,
    color: "purple",
  },
]

const timeline = [
  {
    anno: "2019",
    titolo: "Diploma Liceo scientifico",
    desc: "Un percorso fondato su matematica, metodo analitico e ragionamento strutturato. Qui nasce il mio interesse per la tecnologia.",
    attuale: false,
  },
  {
    anno: "2023",
    titolo: "Laurea in Ingegneria Informatica",
    desc: "Tre anni dedicati a programmazione, algoritmi, sviluppo software e architetture informatiche.",
    attuale: false,
  },
  {
    anno: "2024 — oggi",
    titolo: "Frontend Development & UI Design",
    desc: "Sviluppo interfacce web moderne con Astro, TypeScript e Tailwind CSS, combinando precisione tecnica e design.",
    attuale: true,
  },
]
const strumenti = [
  "Astro",
  "JavaScript",
  "TypeScript",
  "Tailwind CSS",
  "Figma",
  "Iconify",
  "Resend",
  "Git",
  "GitHub",
  "Vercel",
  "Cursor",
]
---

<Layout title="Olga Marrazzo — Frontend Developer">

<!-- ═══════ NOISE OVERLAY ═══════ -->
<div class="noise-overlay"></div>

<!-- ═══════ FIXED HERO BACKGROUND ═══════ -->

<div class="hero-bg" id="heroBg">
    <!-- IMMAGINE SFONDO -->
  <img
  class="hero-img"
  src="/hero-bg.jpeg"
  alt="Scrivania futuristica con ologrammi e neon"
  loading="eager"
/>
  <div class="hero-overlay"></div>
  <div class="hero-vignette"></div>
  <div class="ptc p1"></div>
  <div class="ptc p2"></div>
  <div class="ptc p3"></div>
  <div class="ptc p4"></div>
  <div class="ptc p5"></div>
  <div class="ptc p6"></div>
  <div class="ptc p7"></div>
  <div class="ptc p8"></div>
</div>


<!-- ═══════ HERO CONTENT ═══════ -->
<div class="hero-content" id="heroContent">
  <p class="hero-sub">
  <span class="hero-gradient">
    Front-end Developer
  </span>
</p>

  <h1 class="hero-name">
    Olga<br class="sm:hidden" /> Marrazzo
  </h1>

  <p class="hero-tag">
    Creo esperienze digitali tra design e tecnologia
  </p>

  <div class="hero-buttons">
    <a href="/progetti" class="btn-primary">
      Scopri i miei progetti
      <iconify-icon
        icon="lucide:arrow-down"
        width="16"
        class="ml-1.5">
      </iconify-icon>
    </a>

    <a href="/contatti" class="btn-outline">
      Contattami
    </a>
  </div>
</div>

<div class="scroll-indicator" id="scrollInd">
  <span class="scroll-ind-text">Scroll</span>
  <div class="scroll-line"></div>
</div>

<!-- ═══════ CONTENT WRAPPER ═══════ -->
<div class="content-wrapper">
  <div class="hero-spacer"></div>

  <!-- ─── SKILLS ─── -->
  <section id="skills" class="section-fade section-fade-1 py-20 md:py-28 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="rv mb-12">
        <span class="section-label">Competenze</span>
        <h2 class="section-title">Skills</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-5">
        {skills.map((item, i) => (
          <div class="gc p-7 rv" style={`transition-delay: ${0.08 + i * 0.08}s`}>
            <div class="flex items-center gap-3.5 mb-5">
              <div class={`w-10 h-10 rounded-xl ${item.color === 'cyan' ? 'bg-cyan-500/10' : 'bg-purple-500/10'} flex items-center justify-center shrink-0`}>
                <iconify-icon icon={item.icona} width="20" class={item.color === 'cyan' ? 'text-cyan-400' : 'text-purple-400'}></iconify-icon>
              </div>
              <h3 class="text-[17px] font-medium tracking-tight text-white">{item.titolo}</h3>
            </div>
            <p class="text-[13px] text-white/45 leading-relaxed mb-5">{item.desc}</p>
            <div class="sk-bar">
              <div class="sk-fill" data-w={item.livello}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── PERCORSO — TIMELINE ORIZZONTALE ─── -->
  <section id="percorso" class="section-fade section-fade-2 py-20 md:py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="rv mb-14">
        <span class="section-label">Percorso</span>
        <h2 class="section-title">Il mio percorso</h2>
      </div>

      <div class="timeline-h rv" style="transition-delay: 0.1s;">
        <!-- Linea orizzontale -->
        <div class="tl-line"></div>

        <div class="tl-track">
          {timeline.map((item, i) => (
            <div class="tl-item">
              <!-- Dot -->
              <div class="tl-dot-wrap">
                <div class={`tl-dot ${item.attuale ? 'tl-dot-active' : ''}`}></div>
                <span class="tl-anno">{item.anno}</span>
              </div>
              <!-- Card -->
              <div class="tl-card gc">
                {item.attuale && (
                  <span class="tl-badge">Attuale</span>
                )}
                <h3 class="text-base font-medium tracking-tight text-white mb-2.5">{item.titolo}</h3>
                <p class="text-[13px] text-white/45 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ─── STACK TECNOLOGICO ─── -->
  <section id="stack" class="section-fade section-fade-3 py-20 md:py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="rv mb-12">
        <span class="section-label">Tecnologie</span>
        <h2 class="section-title">Strumenti che utilizzo</h2>
      </div>
      <div class="flex flex-wrap gap-3">
        {strumenti.map((strumento, i) => (
          <span
            class="tech-tag rv"
            style={`transition-delay: ${0.1 + i * 0.05}s`}
          >
            {strumento}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section id="cta" class="section-fade section-fade-4 py-20 md:py-28 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="gc p-10 md:p-16 text-center rv relative overflow-hidden">
        <div class="absolute -top-20 -right-20 w-64 h-64 rounded-full bg-cyan-500/10 blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-16 -left-16 w-48 h-48 rounded-full bg-purple-500/10 blur-3xl pointer-events-none"></div>
        <div class="relative z-10">
          <h2 class="text-3xl md:text-5xl font-semibold tracking-tight text-white neon-text">Hai un progetto?</h2>
          <p class="mt-5 text-white/50 text-base max-w-xl mx-auto leading-relaxed">
            Scopri i miei lavori oppure contattami per costruire qualcosa insieme.
          </p>
          <div class="flex flex-wrap justify-center gap-4 mt-10">
                        <a href="/progetti" class="btn-outline">
              <iconify-icon icon="lucide:folder-open" width="16" class="mr-1.5"></iconify-icon>
              I miei progetti
            </a>
            </a>
            <a href="/contatti" class="btn-primary">
              <iconify-icon icon="lucide:send" width="16" class="mr-1.5"></iconify-icon>
              Scrivimi
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

</Layout>
<style>
  /* ═══ NOISE (nome diverso da theme.css) ═══ */
  .noise-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px;
  }

  /* ═══ HERO BACKGROUND ═══ */
  .hero-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 0;
    overflow: hidden;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    animation: kenBurns 25s ease-in-out infinite;
    will-change: transform;
  }
  @keyframes kenBurns {
    0%, 100% { transform: scale(1.08) translate(0, 0); }
    25% { transform: scale(1.11) translate(-6px, -4px); }
    50% { transform: scale(1.09) translate(4px, -6px); }
    75% { transform: scale(1.12) translate(-4px, 2px); }
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(10,6,24,0.55) 0%, rgba(10,6,24,0.2) 35%, rgba(10,6,24,0.35) 100%);
    z-index: 1;
  }
  .hero-vignette {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: radial-gradient(ellipse 80% 70% at 30% 50%, transparent 0%, rgba(10,6,24,0.65) 100%);
  }

  /* ═══ PARTICLES ═══ */
  .ptc {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 3;
    filter: blur(0.5px);
  }
  .p1 { width: 4px; height: 4px; background: rgba(0,212,255,0.55); top: 18%; left: 15%; animation: pf1 9s ease-in-out infinite; }
  .p2 { width: 3px; height: 3px; background: rgba(200,80,192,0.5); top: 32%; left: 78%; animation: pf2 11s ease-in-out infinite; }
  .p3 { width: 5px; height: 5px; background: rgba(123,47,247,0.35); top: 55%; left: 30%; animation: pf3 13s ease-in-out infinite; }
  .p4 { width: 3px; height: 3px; background: rgba(0,212,255,0.45); top: 14%; left: 88%; animation: pf1 10s ease-in-out infinite reverse; }
  .p5 { width: 4px; height: 4px; background: rgba(200,80,192,0.35); top: 70%; left: 8%; animation: pf2 12s ease-in-out infinite reverse; }
  .p6 { width: 3px; height: 3px; background: rgba(0,212,255,0.4); top: 45%; left: 65%; animation: pf3 8s ease-in-out infinite reverse; }
  .p7 { width: 3px; height: 3px; background: rgba(123,47,247,0.45); top: 25%; left: 50%; animation: pf1 14s ease-in-out infinite; }
  .p8 { width: 2px; height: 2px; background: rgba(0,212,255,0.5); top: 60%; left: 85%; animation: pf2 10s ease-in-out infinite; }
  @keyframes pf1 {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.5; }
    50% { transform: translate(18px, -22px) scale(1.6); opacity: 1; }
  }
  @keyframes pf2 {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
    50% { transform: translate(-22px, 16px) scale(1.4); opacity: 0.9; }
  }
  @keyframes pf3 {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.35; }
    33% { transform: translate(12px, -18px) scale(1.5); opacity: 0.8; }
    66% { transform: translate(-14px, -28px) scale(1.2); opacity: 0.55; }
  }

  /* ═══ HERO TEXT ═══ */
  .hero-content {
    position: relative;
    z-index: 10;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: 7%;
    padding-right: 6%;
  }
  .hero-sub {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 18px;
    opacity: 0;
    transform: translateY(22px);
    animation: txtIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }
  .hero-name {
    font-size: clamp(46px, 8vw, 100px);
    font-weight: 600;
    line-height: 0.93;
    letter-spacing: -0.045em;
    margin-bottom: 26px;
    opacity: 0;
    transform: translateY(32px);
    animation: txtIn 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
    text-shadow: 0 0 80px rgba(123, 47, 247, 0.25), 0 2px 30px rgba(0, 0, 0, 0.6);
  }
  .hero-tag {
    font-size: clamp(15px, 1.8vw, 21px);
    font-weight: 300;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.65);
    max-width: 480px;
    opacity: 0;
    transform: translateY(22px);
    animation: txtIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.85s forwards;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.6);
  }
  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 40px;
    opacity: 0;
    animation: txtIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) 1.1s forwards;
  }
  .hero-gradient {
    background: linear-gradient(90deg, rgb(103 232 249), rgb(217 70 239));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter: drop-shadow(0 0 12px rgba(34,211,238,.25));
  }
  @keyframes txtIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══ SCROLL INDICATOR ═══ */
  .scroll-indicator {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
    animation: txtIn 0.8s ease 1.6s forwards;
  }
  .scroll-ind-text {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
  }
  .scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.35), transparent);
    animation: sPulse 2.2s ease-in-out infinite;
  }
  @keyframes sPulse {
    0%, 100% { opacity: 0.35; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.15); }
  }

  /* ═══ CONTENT WRAPPER ═══ */
  .content-wrapper {
    position: relative;
    z-index: 10;
  }
  .hero-spacer {
    height: 100vh;
  }

  /* ═══ SECTION FADES (transizione world-scroll) ═══ */
  .section-fade-1 { background: linear-gradient(to bottom, rgba(10,6,24,0.72), rgba(10,6,24,0.88)); }
  .section-fade-2 { background: linear-gradient(to bottom, rgba(10,6,24,0.88), rgba(10,6,24,0.94)); }
  .section-fade-3 { background: linear-gradient(to bottom, rgba(10,6,24,0.94), rgba(10,6,24,0.97)); }
  .section-fade-4 { background: rgba(10,6,24,0.98); }

  /* ═══ HORIZONTAL TIMELINE ═══ */
  .timeline-h {
    position: relative;
    padding-top: 32px;
  }
  .tl-line {
    position: absolute;
    top: 39px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.08) 15%, rgba(0,212,255,0.2) 50%, rgba(255,255,255,0.08) 85%, transparent);
  }
  .tl-track {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    position: relative;
  }
  .tl-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .tl-dot-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    position: relative;
    z-index: 2;
  }
  .tl-dot {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: 3px solid #0a0618;
    flex-shrink: 0;
    transition: all 0.4s ease;
  }
  .tl-dot-active {
    background: #00d4ff;
    box-shadow: 0 0 14px rgba(0, 212, 255, 0.5), 0 0 30px rgba(0, 212, 255, 0.15);
  }
  .tl-item:hover .tl-dot:not(.tl-dot-active) {
    background: rgba(0, 212, 255, 0.5);
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
  }
  .tl-anno {
    font-size: 12px;
    font-weight: 500;
    color: rgba(0, 212, 255, 0.65);
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .tl-card {
    width: 100%;
    padding: 24px;
    position: relative;
  }
  .tl-badge {
    position: absolute;
    top: -8px;
    right: 20px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 8px;
    background: rgba(0, 212, 255, 0.12);
    color: #00d4ff;
    border: 1px solid rgba(0, 212, 255, 0.18);
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 1023px) {
    .tl-track {
      display: flex;
      overflow-x: auto;
      gap: 20px;
      padding-bottom: 16px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }
    .tl-track::-webkit-scrollbar { height: 3px; }
    .tl-track::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.03); border-radius: 2px; }
    .tl-track::-webkit-scrollbar-thumb { background: rgba(0, 212, 255, 0.25); border-radius: 2px; }
    .tl-item {
      min-width: 280px;
      max-width: 300px;
      flex-shrink: 0;
      scroll-snap-align: start;
    }
    .tl-line { display: none; }
  }
  @media (max-width: 768px) {
    .hero-content {
      padding-left: 6%;
      padding-right: 6%;
    }
  }

    @media (max-width: 768px) {
    .hero-content {
      padding-left: 6%;
      padding-right: 6%;
    }
    .hero-img {
      object-position: 65% 40%;
    }
  }
</style>

<script>

  const scrollInd = document.getElementById('scrollInd');
  const heroC = document.getElementById('heroContent');

  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    const vh = window.innerHeight;

    if (scrollInd) {
      scrollInd.style.opacity = Math.max(0, 1 - y / 180);
    }

    if (heroC) {
      heroC.style.transform = `translateY(${y * 0.28}px)`;
      heroC.style.opacity = Math.max(0, 1 - y / (vh * 0.7));
    }
  }, { passive: true });

  // ── Reveal on scroll ──
  const rvObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add('vis');
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -30px 0px' }
  );
  document.querySelectorAll('.rv').forEach((el) => rvObs.observe(el));
    // ── Skill bars animation ──
  const skObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const w = e.target.getAttribute('data-w');
          setTimeout(() => {
            e.target.style.width = w + '%';
          }, 400);
          skObs.unobserve(e.target);
        }
      });
    },
    { threshold: 0.3 }
  );
  document.querySelectorAll('.sk-fill').forEach((el) => skObs.observe(el));
  </script>