---
import Layout from '../layouts/Layout.astro'

const skills = [
  {
    titolo: "HTML & Tailwind CSS",
    desc: "Markup semantico, layout utility-first con Grid e Flexbox, classi responsive.",
    icona: "lucide:code-2",
    livello: 88,
    color: "cyan",
  },
  {
    titolo: "Astro",
    desc: "Routing basato su file, composizione componenti con slot, dati dinamici nel frontmatter.",
    icona: "lucide:rocket",
    livello: 80,
    color: "purple",
  },
  {
    titolo: "JavaScript",
    desc: "Sintassi ES6+, Fetch API, IntersectionObserver, manipolazione DOM e gestione eventi.",
    icona: "lucide:braces",
    livello: 82,
    color: "cyan",
  },
  {
    titolo: "Animazioni CSS",
    desc: "Keyframe personalizzati, reveal allo scroll, effetto parallax, glassmorphism.",
    icona: "lucide:sparkles",
    livello: 85,
    color: "purple",
  },
  {
    titolo: "UI Design & Figma",
    desc: "Prototipazione ad alta fedeltà, creazione design system, gerarchia visiva e specifiche componente.",
    icona: "lucide:layout",
    livello: 78,
    color: "cyan",
  },
  {
    titolo: "Integrazione API",
    desc: "Comunicazione client-server con Fetch, gestione form data, servizio email Resend.",
    icona: "lucide:plug",
    livello: 75,
    color: "purple",
  },
  {
    titolo: "Responsive Design",
    desc: "Approccio mobile-first, media queries CSS, breakpoint Tailwind, layout adattivi.",
    icona: "lucide:smartphone",
    livello: 85,
    color: "cyan",
  },
  {
    titolo: "UI / UX Design",
    desc: "Design system coerente tra pagine, estetica dark cinematografica, interazioni fluide.",
    icona: "lucide:pen-tool",
    livello: 78,
    color: "purple",
  },
]

const timeline = [
  {
    anno: "2019",
    titolo: "Diploma Liceo scientifico",
    desc: "Un percorso fondato su matematica, metodo analitico e ragionamento strutturato. Qui nasce il mio interesse per la tecnologia.",
    attuale: false,
  },
  {
    anno: "2023",
    titolo: "Laurea in Ingegneria Informatica",
    desc: "Tre anni dedicati a programmazione, algoritmi, sviluppo software e architetture informatiche.",
    attuale: false,
  },
  {
    anno: "2024 — oggi",
    titolo: "Frontend Development & UI Design",
    desc: "Sviluppo interfacce web moderne con Astro, TypeScript e Tailwind CSS, combinando precisione tecnica e design.",
    attuale: true,
  },
]
const strumenti = [
  "Astro",
  "JavaScript",
  "TypeScript",
  "Tailwind CSS",
  "Figma",
  "Iconify",
  "Resend",
  "Git",
  "GitHub",
  "Vercel",
  "Cursor",
]
---

<Layout title="Olga Marrazzo — Frontend Developer" description="Portfolio di Olga Marrazzo, Frontend Developer. Creo esperienze digitali tra design e tecnologia con Astro, Tailwind CSS e TypeScript.">

<!-- ═══════ HERO BACKGROUND — DAY / NIGHT CROSSFADE ═══════ -->
<div class="hero-bg" aria-hidden="true">
  <!-- Livello NOTTE (sotto) — visibile quando il giorno sfuma -->
  <img
    class="hero-img hero-night"
    src="/dark-bg1.jpeg"
    alt=""
    fetchpriority="high"
  />
  <!-- Livello GIORNO (sopra) — sfuma allo scroll -->
  <img
    class="hero-img hero-day"
    src="/hero-bg3.png"
    alt=""
    fetchpriority="high"
  />
  <!-- Stelle twinkle (sopra la notte, sotto il giorno) -->
  <canvas id="starsCanvas" class="hero-stars"></canvas>
</div>

<!-- ═══════ HERO CONTENT ═══════ -->
<div class="hero-content" id="heroContent">
  <p class="hero-sub">
    <span class="hero-gradient">
      Front-end Developer
    </span>
  </p>

  <h1 class="hero-name">
    Olga<br class="sm:hidden" /> Marrazzo
  </h1>

  <p class="hero-tag">
    Creo esperienze digitali dove design e tecnologia si fondono,
    trasformando idee in interfacce web moderne e funzionali.
  </p>

  <div class="hero-buttons">
    <a href="/progetti" class="btn-primary">
      Scopri i miei progetti
      <iconify-icon
        icon="lucide:arrow-down"
        width="16"
        class="ml-1.5"
        aria-hidden="true">
      </iconify-icon>
    </a>

    <a href="/contatti" class="btn-outline">
      Contattami
    </a>
  </div>
</div>

<div class="scroll-indicator" id="scrollInd" aria-hidden="true">
  <span class="scroll-ind-text">Scroll</span>
  <div class="scroll-line"></div>
</div>

<!-- ═══════ CONTENT WRAPPER ═══════ -->
<div class="content-wrapper">

  <!-- ─── SKILLS ─── -->
  <section id="skills" class="skills-section py-20 md:py-28 px-6">

    <!-- Sfondo notturno (continuità con hero night) -->
    <img
      src="/dark-bg1.jpeg"
      alt=""
      class="skills-bg"
      aria-hidden="true"
    />

    <!-- Overlay per leggibilità -->
    <div class="skills-overlay"></div>

    <!-- Contenuto -->
    <div class="relative z-10 max-w-5xl mx-auto">

      <div class="rv mb-12">
        <span class="section-label">
          Competenze
        </span>
        <h2 class="section-title">
          Skills
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-5">

        {skills.map((item, i) => (

          <div
            class={`gc skill-card skill-card--${item.color} p-7 rv`}
            style={`transition-delay: ${0.08 + i * 0.08}s`}
          >
            <!-- Bordo fluo animato -->
            <div class={`skill-glow skill-glow--${item.color}`}></div>

            <div class="flex items-center gap-3.5 mb-5">
              <div
                class={`w-10 h-10 rounded-xl ${
                  item.color === 'cyan'
                    ? 'bg-cyan-500/10 skill-icon-box--cyan'
                    : 'bg-purple-500/10 skill-icon-box--purple'
                } flex items-center justify-center shrink-0`}
              >
                <iconify-icon
                  icon={item.icona}
                  width="20"
                  class={
                    item.color === 'cyan'
                      ? 'text-cyan-400'
                      : 'text-purple-400'
                  }
                  aria-hidden="true">
                </iconify-icon>
              </div>

              <h3 class="text-[17px] font-medium tracking-tight text-white">
                {item.titolo}
              </h3>
            </div>

            <p class="text-[13px] text-white/55 leading-relaxed mb-5">
              {item.desc}
            </p>

            <!-- Barra skill con effetto fluo -->
            <div class={`sk-bar sk-bar--${item.color}`}>
              <div
                class={`sk-fill sk-fill--${item.color}`}
                data-w={item.livello}
              >
                <!-- Shimmer scorrevole -->
                <div class="sk-shimmer"></div>
              </div>
              <span class="sk-percent">{item.livello}%</span>
            </div>

          </div>

        ))}

      </div>
    </div>

  </section>

  <!-- ─── PERCORSO — TIMELINE ORIZZONTALE ─── -->
  <section id="percorso" class="section-fade section-fade-2 py-20 md:py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="rv mb-14">
        <span class="section-label">Percorso</span>
        <h2 class="section-title">Il mio percorso</h2>
      </div>

      <div class="timeline-h rv" style="transition-delay: 0.1s;">
        <div class="tl-line"></div>
        <div class="tl-track">
          {timeline.map((item, i) => (
            <div class="tl-item">
              <div class="tl-dot-wrap">
                <div class={`tl-dot ${item.attuale ? 'tl-dot-active' : ''}`}></div>
                <span class="tl-anno">{item.anno}</span>
              </div>
              <div class="tl-card gc">
                {item.attuale && (
                  <span class="tl-badge">Attuale</span>
                )}
                <h3 class="text-base font-medium tracking-tight text-white mb-2.5">{item.titolo}</h3>
                <p class="text-[13px] text-white/45 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ─── STACK TECNOLOGICO ─── -->
  <section id="stack" class="section-fade section-fade-3 py-20 md:py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="rv mb-12">
        <span class="section-label">Tecnologie</span>
        <h2 class="section-title">Strumenti che utilizzo</h2>
      </div>
      <div class="flex flex-wrap gap-3">
        {strumenti.map((strumento, i) => (
          <span
            class="tech-tag rv"
            style={`transition-delay: ${0.1 + i * 0.05}s`}
          >
            {strumento}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section id="cta" class="section-fade section-fade-4 py-20 md:py-28 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="gc p-10 md:p-16 text-center rv relative overflow-hidden">
        <div class="absolute -top-20 -right-20 w-64 h-64 rounded-full bg-cyan-500/10 blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-16 -left-16 w-48 h-48 rounded-full bg-purple-500/10 blur-3xl pointer-events-none"></div>
        <div class="relative z-10">
          <h2 class="text-3xl md:text-5xl font-semibold tracking-tight text-white neon-text">Hai un progetto?</h2>
          <p class="mt-5 text-white/50 text-base max-w-xl mx-auto leading-relaxed">
            Scopri i miei lavori oppure contattami per costruire qualcosa insieme.
          </p>
          <div class="flex flex-wrap justify-center gap-4 mt-10">
            <a href="/progetti" class="btn-outline">
              <iconify-icon icon="lucide:folder-open" width="16" class="mr-1.5" aria-hidden="true"></iconify-icon>
              I miei progetti
            </a>
            <a href="/contatti" class="btn-primary">
              <iconify-icon icon="lucide:send" width="16" class="mr-1.5" aria-hidden="true"></iconify-icon>
              Scrivimi
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

</Layout>

<style>
  /* ═══════════════════════════════════════════
     HERO BACKGROUND — DAY / NIGHT CROSSFADE
     ═══════════════════════════════════════════ */
  .hero-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 0;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }

  /* Livello notte — sempre presente sotto */
  .hero-night {
    z-index: 1;
    filter: brightness(0.6) saturate(1.3);
  }

  /* Livello giorno — sopra, sfuma allo scroll via JS */
  .hero-day {
    z-index: 2;
    transition: opacity 0.05s linear;
  }

  /* Canvas stelle — tra notte e giorno */
  .hero-stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  /* ═══ HERO TEXT ═══ */
  .hero-content {
    position: relative;
    z-index: 10;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding-left: 6%;
    padding-right: 6%;
  }

  .hero-sub {
    color: rgba(26,26,26,.65);
    font-family: "Inter", sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: .35em;
    text-transform: uppercase;
    margin-bottom: 22px;
    opacity: 0;
    transform: translateY(20px);
    animation: txtIn .9s ease .3s forwards;
  }

  .hero-name {
    color: #1a1a1a;
    font-family: "Playfair Display", serif;
    font-size: clamp(52px, 8vw, 110px);
    font-weight: 400;
    line-height: .95;
    letter-spacing: -0.04em;
    margin-bottom: 28px;
    opacity: 0;
    transform: translateY(30px);
    animation: txtIn 1s ease .5s forwards;
    text-shadow: 0 2px 12px rgba(255,255,255,.35);
  }

  .hero-tag {
    color: rgba(26,26,26,.85);
    font-family: "Inter", sans-serif;
    font-size: clamp(16px,2vw,22px);
    font-weight: 300;
    line-height: 1.6;
    max-width: 520px;
    opacity: 0;
    transform: translateY(20px);
    animation: txtIn .9s ease .7s forwards;
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 40px;
    opacity: 0;
    animation: txtIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) 1.1s forwards;
  }

  .hero-gradient {
    color: rgba(26,26,26,.85);
    background: none;
    -webkit-text-fill-color: white;
    filter: none;
  }

  @keyframes txtIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══ SCROLL INDICATOR ═══ */
  .scroll-indicator {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
    animation: txtIn 0.8s ease 1.6s forwards;
  }
  .scroll-ind-text {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
  }
  .scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.35), transparent);
    animation: sPulse 2.2s ease-in-out infinite;
  }
  @keyframes sPulse {
    0%, 100% { opacity: 0.35; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.15); }
  }

  /* ═══ CONTENT WRAPPER ═══ */
  .content-wrapper {
    position: relative;
    z-index: 5;
  }

  /* ═══════════════════════════════════════════
     SKILLS SECTION — NIGHT BACKGROUND
     ═══════════════════════════════════════════ */
  .skills-section {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    margin-top: 0px;
    padding-top: 100px;
    /* Fallback: se il body non è ancora colorato via JS, la sezione ha comunque un bg notte */
    background: #080814;
  }

  .skills-section::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    width: 100%;
    height: 320px;
    z-index: 2;
    background:
      linear-gradient(
        to bottom,
        transparent 0%,
        rgba(8,8,20,.3) 25%,
        rgba(8,8,20,.7) 60%,
        rgba(8,8,20,.95) 100%
      );
    pointer-events: none;
  }

  .skills-bg {
    position: absolute;
    top: -200px;
    left: 0;
    width: 100%;
    height: calc(100% + 200px);
    object-fit: cover;
    object-position: center 20%;
    z-index: 0;
    /* Stessa immagine della hero-night → continuità visiva perfetta */
    /* Estesa 200px verso l'alto per coprire la fascia nera */
    filter: brightness(0.5) saturate(1.4);
  }

  .skills-overlay {
    position: absolute;
    top: -200px;
    left: 0;
    width: 100%;
    height: calc(100% + 200px);
    background:
      linear-gradient(
        to bottom,
        rgba(8,8,20,.05),
        rgba(8,8,20,.15) 25%,
        rgba(8,8,20,.6)
      );
    z-index: 1;
    pointer-events: none;
  }

  /* ═══════════════════════════════════════════
     SKILL CARD — FLUO GLOW BORDER
     ═══════════════════════════════════════════ */
  .skill-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    background: rgba(8,8,20,0.45);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition: transform 0.35s ease, border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .skill-card:hover {
    transform: translateY(-3px);
  }

  /* Bordo fluo animato (pseudo-elemento rotante) */
  .skill-glow {
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.5s ease;
    overflow: hidden;
  }

  .skill-glow::before {
    content: "";
    position: absolute;
    inset: -50%;
    background: conic-gradient(
      from 0deg,
      transparent 0%,
      transparent 40%,
      var(--glow-color) 50%,
      transparent 60%,
      transparent 100%
    );
    animation: glowSpin 4s linear infinite;
  }

  .skill-card:hover .skill-glow {
    opacity: 1;
  }

  /* Varianti colore fluo */
  .skill-glow--cyan {
    --glow-color: rgba(0, 212, 255, 0.5);
  }
  .skill-glow--purple {
    --glow-color: rgba(168, 85, 247, 0.5);
  }

  .skill-card--cyan:hover {
    border-color: rgba(0, 212, 255, 0.2);
    box-shadow:
      0 0 20px rgba(0, 212, 255, 0.08),
      inset 0 0 20px rgba(0, 212, 255, 0.03);
  }
  .skill-card--purple:hover {
    border-color: rgba(168, 85, 247, 0.2);
    box-shadow:
      0 0 20px rgba(168, 85, 247, 0.08),
      inset 0 0 20px rgba(168, 85, 247, 0.03);
  }

  @keyframes glowSpin {
    to { transform: rotate(360deg); }
  }

  /* Icon box hover glow */
  .skill-icon-box--cyan {
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  .skill-card--cyan:hover .skill-icon-box--cyan {
    background: rgba(0, 212, 255, 0.18);
    box-shadow: 0 0 16px rgba(0, 212, 255, 0.15);
  }
  .skill-icon-box--purple {
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  .skill-card--purple:hover .skill-icon-box--purple {
    background: rgba(168, 85, 247, 0.18);
    box-shadow: 0 0 16px rgba(168, 85, 247, 0.15);
  }

  /* ═══════════════════════════════════════════
     SKILL BAR — FLUO / NEON EFFECT
     ═══════════════════════════════════════════ */
  .sk-bar {
    position: relative;
    width: 100%;
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }

  .sk-bar--cyan {
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.05);
  }
  .sk-bar--purple {
    box-shadow: 0 0 8px rgba(168, 85, 247, 0.05);
  }

  .sk-fill {
    position: relative;
    height: 100%;
    border-radius: 999px;
    width: 0%;
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
  }

  /* Colore fluo — cyan */
  .sk-fill--cyan {
    background: linear-gradient(90deg, #00d4ff, #00e5ff, #00bcd4);
    box-shadow:
      0 0 12px rgba(0, 212, 255, 0.5),
      0 0 24px rgba(0, 212, 255, 0.2),
      0 0 4px rgba(0, 212, 255, 0.8);
  }

  /* Colore fluo — purple */
  .sk-fill--purple {
    background: linear-gradient(90deg, #a855f7, #c084fc, #9333ea);
    box-shadow:
      0 0 12px rgba(168, 85, 247, 0.5),
      0 0 24px rgba(168, 85, 247, 0.2),
      0 0 4px rgba(168, 85, 247, 0.8);
  }

  /* Shimmer — luce che scorre nella barra */
  .sk-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.35) 50%,
      transparent 100%
    );
    transform: translateX(-100%);
    animation: shimmerSlide 2.5s ease-in-out infinite;
    animation-delay: 1.5s;
  }

  @keyframes shimmerSlide {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(200%); }
  }

  /* Percentuale affiancata alla barra */
  .sk-percent {
    position: absolute;
    right: 0;
    top: -22px;
    font-size: 11px;
    font-weight: 600;
    font-family: "Inter", sans-serif;
    letter-spacing: 0.04em;
    opacity: 0;
    transition: opacity 0.6s ease 1.4s;
  }
  .sk-bar--cyan .sk-percent {
    color: #00d4ff;
    text-shadow: 0 0 8px rgba(0, 212, 255, 0.4);
  }
  .sk-bar--purple .sk-percent {
    color: #c084fc;
    text-shadow: 0 0 8px rgba(168, 85, 247, 0.4);
  }

  /* Mostra % quando la barra è animata */
  .sk-fill[data-animated="true"] + .sk-percent,
  .sk-fill[data-visible="true"] ~ .sk-percent {
    opacity: 1;
  }

  /* ═══ SECTION FADES ═══ */
  .section-fade-1,
  .section-fade-2,
  .section-fade-3,
  .section-fade-4 {
    background: transparent;
  }

  /* ═══ HORIZONTAL TIMELINE ═══ */
  .timeline-h {
    position: relative;
    padding-top: 32px;
  }
  .tl-line {
    position: absolute;
    top: 39px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.08) 15%, rgba(0,212,255,0.2) 50%, rgba(255,255,255,0.08) 85%, transparent);
  }
  .tl-track {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    position: relative;
  }
  .tl-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .tl-dot-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    position: relative;
    z-index: 2;
  }
  .tl-dot {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: 3px solid #0a0618;
    flex-shrink: 0;
    transition: all 0.4s ease;
  }
  .tl-dot-active {
    background: #00d4ff;
    box-shadow: 0 0 14px rgba(0, 212, 255, 0.5), 0 0 30px rgba(0, 212, 255, 0.15);
  }
  .tl-item:hover .tl-dot:not(.tl-dot-active) {
    background: rgba(0, 212, 255, 0.5);
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
  }
  .tl-anno {
    font-size: 12px;
    font-weight: 500;
    color: rgba(0, 212, 255, 0.65);
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .tl-card {
    width: 100%;
    padding: 24px;
    position: relative;
  }
  .tl-badge {
    position: absolute;
    top: -8px;
    right: 20px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 8px;
    background: rgba(0, 212, 255, 0.12);
    color: #00d4ff;
    border: 1px solid rgba(0, 212, 255, 0.18);
  }

  /* ═══════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════ */
  @media (max-width: 1023px) {
    .tl-track {
      display: flex;
      overflow-x: auto;
      gap: 20px;
      padding-bottom: 16px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }
    .tl-track::-webkit-scrollbar { height: 3px; }
    .tl-track::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.03); border-radius: 2px; }
    .tl-track::-webkit-scrollbar-thumb { background: rgba(0, 212, 255, 0.25); border-radius: 2px; }
    .tl-item {
      min-width: 280px;
      max-width: 300px;
      flex-shrink: 0;
      scroll-snap-align: start;
    }
    .tl-line { display: none; }
  }

  @media (max-width: 768px) {
    .hero-content {
      padding-left: 6%;
      padding-right: 6%;
    }
    .hero-img {
      object-position: center top;
      transform: scale(1.15);
      animation: none;
      will-change: auto;
    }
    .skill-card {
      padding: 1.25rem;
    }
  }
</style>

<script>
  // ═══════════════════════════════════════════
  //  DAY → NIGHT CROSSFADE ON SCROLL
  // ═══════════════════════════════════════════

  const heroDay = document.querySelector('.hero-day');
  const heroNight = document.querySelector('.hero-night');
  const starsCanvas = document.getElementById('starsCanvas');
  const scrollInd = document.getElementById('scrollInd');
  const heroC = document.getElementById('heroContent');

  // ── Stelle twinkle su canvas ──
  function initStars() {
    if (!starsCanvas) return;
    const ctx = starsCanvas.getContext('2d');
    let w, h, stars = [];

    function resize() {
      w = starsCanvas.width = window.innerWidth;
      h = starsCanvas.height = window.innerHeight;
      stars = [];
      const count = Math.floor((w * h) / 4000);
      for (let i = 0; i < count; i++) {
        stars.push({
          x: Math.random() * w,
          y: Math.random() * h,
          r: Math.random() * 1.5 + 0.3,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.02 + 0.005,
          brightness: Math.random() * 0.6 + 0.4,
        });
      }
    }

    function draw(time) {
      ctx.clearRect(0, 0, w, h);
      for (const s of stars) {
        const twinkle = (Math.sin(time * s.speed + s.phase) + 1) / 2;
        const alpha = s.brightness * twinkle;
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(200, 220, 255, ${alpha})`;
        ctx.fill();
      }
      requestAnimationFrame(draw);
    }

    resize();
    window.addEventListener('resize', resize, { passive: true });
    requestAnimationFrame(draw);
  }

  initStars();

  // ── Scroll handler: crossfade giorno→notte ──
  let ticking = false;

  function onScroll() {
    if (ticking) return;
    ticking = true;

    requestAnimationFrame(() => {
      const y = window.scrollY;
      const vh = window.innerHeight;

      // Progress: 0 (top) → 1 (1 viewport scrolled)
      const progress = Math.min(y / vh, 1);

      // GIORNO: sfuma via
      if (heroDay) {
        // Curva d'uscita più dolce: inizia a svanire al 10%, scompare al 90%
        const dayOpacity = 1 - smoothstep(0.05, 0.75, progress);
        heroDay.style.opacity = dayOpacity;
      }

      // NOTTE: aumenta luminosità
      if (heroNight) {
        const nightBright = 0.4 + smoothstep(0.2, 0.8, progress) * 0.5;
        heroNight.style.filter = `brightness(${nightBright}) saturate(1.3)`;
      }

      // STELLE: appaiono col buio
      if (starsCanvas) {
        const starsOpacity = smoothstep(0.15, 0.6, progress);
        starsCanvas.style.opacity = starsOpacity;
      }

      // BODY BACKGROUND: transizione celeste → scuro via inline style
      // (Gli scoped style di Astro NON raggiungono il tag <body> in Layout.astro)
      const skyDay = '#9FD5F1';  // ← Celeste cielo — cambialo col colore esatto della tua immagine
      const skyNight = '#080814';
      const nightProg = smoothstep(0.2, 0.65, progress);
      // Interpola il colore del body da celeste a scuro
      const br = Math.round(159 * (1 - nightProg) + 8 * nightProg);
      const bg = Math.round(213 * (1 - nightProg) + 8 * nightProg);
      const bb = Math.round(241 * (1 - nightProg) + 20 * nightProg);
      document.body.style.background = `rgb(${br},${bg},${bb})`;

      // Scroll indicator fade
      if (scrollInd) {
        scrollInd.style.opacity = Math.max(0, 1 - y / 180);
      }

      // Hero parallax + fade
      if (heroC) {
        heroC.style.transform = `translateY(${y * 0.28}px)`;
        heroC.style.opacity = Math.max(0, 1 - y / (vh * 0.7));

        // Testo hero: cambia colore verso toni lunari col progredire
        const heroName = heroC.querySelector('.hero-name');
        const heroTag = heroC.querySelector('.hero-tag');
        const heroSub = heroC.querySelector('.hero-sub');

        if (heroName) {
          const dayFade = 1 - progress;
          // Da nero (#1a1a1a) a bianco lunare
          const r = Math.round(26 + (255 - 26) * progress * 0.6);
          const g = Math.round(26 + (255 - 26) * progress * 0.6);
          const b = Math.round(26 + (255 - 26) * progress * 0.65);
          heroName.style.color = `rgb(${r},${g},${b})`;
          heroName.style.textShadow = progress > 0.3
            ? `0 0 30px rgba(0,212,255,${progress * 0.15})`
            : `0 2px 12px rgba(255,255,255,.35)`;
        }

        if (heroTag) {
          const alpha = 0.85 - progress * 0.3;
          heroTag.style.color = `rgba(255,255,255,${alpha})`;
        }

        if (heroSub) {
          const spanEl = heroSub.querySelector('.hero-gradient');
          if (spanEl) {
            spanEl.style.color = `rgba(255,255,255,${0.6 + progress * 0.3})`;
          }
        }
      }

      ticking = false;
    });
  }

  // Funzione di easing smooth
  function smoothstep(edge0, edge1, x) {
    const t = Math.max(0, Math.min(1, (x - edge0) / (edge1 - edge0)));
    return t * t * (3 - 2 * t);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  // Imposta il body celeste al caricamento e sincronizza lo scroll
  document.body.style.background = '#9FD5F1';
  onScroll();

  // ═══════════════════════════════════════════
  //  SKILL BARS — Anima allo scroll
  // ═══════════════════════════════════════════

  const skObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const fill = e.target;
          const w = fill.getAttribute('data-w');
          setTimeout(() => {
            fill.style.width = w + '%';
            fill.setAttribute('data-visible', 'true');
          }, 400);
          skObs.unobserve(fill);
        }
      });
    },
    { threshold: 0.3 }
  );
  document.querySelectorAll('.sk-fill').forEach((el) => skObs.observe(el));
</script>
