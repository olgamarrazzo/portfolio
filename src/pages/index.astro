---
import Layout from '../layouts/Layout.astro'

const skills = [
  {
    titolo: "HTML & CSS",
    desc: "Markup semantico, Tailwind CSS, layout responsive con Grid e Flexbox.",
    icona: "lucide:code-2",
    livello: 3,
    color: "cyan",
  },
  {
    titolo: "Astro",
    desc: "Routing basato su file, composizione componenti, Island Architecture.",
    icona: "lucide:rocket",
    livello: 3,
    color: "purple",
  },
  {
    titolo: "JavaScript",
    desc: "ES6+, manipolazione DOM, Fetch API, IntersectionObserver.",
    icona: "lucide:braces",
    livello: 2,
    color: "cyan",
  },
  {
    titolo: "TypeScript",
    desc: "Tipizzazione statica, interfacce, generici per codice più robusto.",
    icona: "lucide:file-code",
    livello: 2,
    color: "purple",
  },
  {
    titolo: "Animazioni CSS",
    desc: "Keyframe, transizioni, reveal allo scroll, micro-interazioni.",
    icona: "lucide:sparkles",
    livello: 3,
    color: "cyan",
  },
  {
    titolo: "UI Design & Figma",
    desc: "Prototipazione, design system, gerarchia visiva e specifiche componente.",
    icona: "lucide:layout",
    livello: 2,
    color: "purple",
  },
  {
    titolo: "Responsive Design",
    desc: "Approccio mobile-first, media queries, layout adattivi per ogni dispositivo.",
    icona: "lucide:smartphone",
    livello: 3,
    color: "cyan",
  },
]

const timeline = [
  {
    anno: "2019",
    titolo: "Diploma Liceo scientifico",
    desc: "Percorso fondato su metodo analitico e ragionamento strutturato.",
    attuale: false,
  },
  {
    anno: "2023",
    titolo: "Laurea in Ingegneria Informatica",
    desc: "Programmazione, algoritmi, sviluppo software e architetture.",
    attuale: false,
  },
  {
    anno: "2024 — oggi",
    titolo: "Frontend Development & UI Design",
    desc: "Interfacce web moderne con Astro, TypeScript e Tailwind CSS.",
    attuale: true,
  },
]
const strumenti = [
  "Astro",
  "JavaScript",
  "TypeScript",
  "Tailwind CSS",
  "Figma",
  "Canva",
  "Git",
  "GitHub",
  "Vercel",
  "Pacchetto Office",
]
---

<Layout title="Olga Marrazzo — Frontend Developer" description="Portfolio di Olga Marrazzo, Frontend Developer. Creo esperienze digitali tra design e tecnologia con Astro, Tailwind CSS e TypeScript.">

<!-- ═══════ HERO BACKGROUND — DAY ═══════ -->
<div class="hero-bg" aria-hidden="true">
  <img class="hero-img hero-day" src="/hero-bg.png" alt="" fetchpriority="high" />
</div>

<!-- ═══════ NIGHT ATMOSPHERE — shared dark-bg + stars ═══════ -->
<div class="night-atmosphere" id="nightAtmosphere" aria-hidden="true">
  <img class="night-atmosphere-img" src="/dark-bg.jpeg" alt="" />
  <canvas id="starsCanvas" class="night-atmosphere-stars"></canvas>
  <div class="night-atmosphere-overlay"></div>
</div>

<!-- ═══════ HERO CONTENT ═══════ -->
<div class="hero-content" id="heroContent">
  <p class="hero-sub">
    <span class="hero-gradient">Front-end Developer</span>
  </p>

  <h1 class="hero-name">
    Olga<br class="sm:hidden" /> Marrazzo
  </h1>

  <p class="hero-tag">
    Creo esperienze digitali dove design e tecnologia si fondono,
    trasformando idee in interfacce web moderne e funzionali.
  </p>

  <div class="hero-buttons">
    <a href="/progetti" class="btn-glass btn-glass--primary">
      Scopri i miei progetti
      <iconify-icon icon="lucide:arrow-down" width="15" class="ml-1.5" aria-hidden="true"></iconify-icon>
    </a>
    <a href="/contatti" class="btn-glass btn-glass--outline">
      Contattami
    </a>
  </div>
</div>

<div class="scroll-indicator" id="scrollInd" aria-hidden="true">
  <span class="scroll-ind-text">Scroll</span>
  <div class="scroll-line"></div>
</div>

<!-- ═══════ CONTENT WRAPPER ═══════ -->
<div class="content-wrapper">

  <!-- ─── SKILLS ─── -->
  <section id="skills" class="skills-section">

    <div class="relative z-10 max-w-5xl mx-auto">
      <div class="rv mb-12">
        <span class="section-label">Competenze</span>
        <h2 class="section-title">Cosa so fare</h2>
        <p class="mt-5 text-sm text-white/50 max-w-lg leading-relaxed">
          Un set di competenze in continuo crescita, maturato attraverso studio, progetti personali e passione per il frontend.
        </p>
      </div>

      <div class="skills-grid">
        {skills.map((s, i) => (
          <div class="skill-card rv" style={`transition-delay: ${0.08 + i * 0.07}s;`}>
            <div class="flex items-center gap-3.5 mb-4">
              <div class="skill-icon-wrap">
                <iconify-icon
                  icon={s.icona}
                  width="20"
                  class={s.color === "cyan" ? "text-cyan-400" : "text-purple-400"}
                  aria-hidden="true"
                ></iconify-icon>
              </div>
              <h3 class="skill-title">{s.titolo}</h3>
            </div>
            <p class="skill-desc">{s.desc}</p>
            <div class="sk-dots">
              {Array.from({ length: 4 }).map((_, di) => (
                <span
                  class:list={[
                    "sk-dot",
                    di < s.livello && (s.color === "cyan" ? "sk-dot--filled" : "sk-dot--purple")
                  ]}
                ></span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>   
  
  <!-- ─── PERCORSO — TIMELINE ORIZZONTALE ─── -->
  <section id="percorso" class="section-fade section-fade-2 py-20 md:py-28 px-6 relative overflow-hidden">

    <div class="max-w-6xl mx-auto relative z-10">
      <div class="rv mb-14">
        <span class="section-label">Percorso</span>
        <h2 class="section-title">Il mio percorso</h2>
      </div>

      <div class="timeline-h rv" style="transition-delay: 0.1s;">
        <div class="tl-line"></div>
        <div class="tl-track">
          {timeline.map((item, i) => (
            <div class="tl-item">
              <div class="tl-dot-wrap">
                <div class={`tl-dot ${item.attuale ? 'tl-dot-active' : ''}`}></div>
                <span class="tl-anno">{item.anno}</span>
              </div>
              <div class="tl-card gc">
                {item.attuale && (
                  <span class="tl-badge">Attuale</span>
                )}
                <h3 class="text-base font-medium tracking-tight text-white mb-2.5">{item.titolo}</h3>
                <p class="text-[13px] text-white/45 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TECH STACK ─── -->
  <section class="tech-section">
    <div class="tech-inner">
      <div class="rv mb-10 text-center">
        <span class="section-label">Strumenti</span>
        <h2 class="section-title">Tecnologie che utilizzo</h2>
      </div>
      <div class="rv flex flex-wrap justify-center gap-3">
        {strumenti.map((s, i) => (
          <span class="tech-tag" style={`transition-delay: ${0.1 + i * 0.05}s;`}>{s}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="cta-section">
    <div class="cta-inner rv">
      <div class="cta-glow cta-glow--cyan" aria-hidden="true"></div>
      <div class="cta-glow cta-glow--purple" aria-hidden="true"></div>
      <h2 class="cta-title">Hai un progetto in mente?</h2>
      <p class="cta-sub">Parliamone insieme e troviamo la soluzione migliore.</p>
      <div class="cta-buttons">
        <a href="/progetti" class="btn-glass btn-glass--outline">
          <iconify-icon icon="lucide:folder-open" width="15" class="mr-1.5" aria-hidden="true"></iconify-icon>
          I miei progetti
        </a>
        <a href="/contatti" class="btn-glass btn-glass--primary">
          <iconify-icon icon="lucide:send" width="15" class="mr-1.5" aria-hidden="true"></iconify-icon>
          Scrivimi
        </a>
      </div>
    </div>
  </section>
</div>

</Layout>

<style>
  /* ═══════════════════════════════════════════
     HERO BACKGROUND — DAY / NIGHT CROSSFADE
     ═══════════════════════════════════════════ */
  .hero-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 2;
    pointer-events: none;
  }
  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }
  .hero-day {
    z-index: 1;
  }

  /* ═══ NIGHT ATMOSPHERE ═══ */
  .night-atmosphere {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
  }
  .night-atmosphere-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    filter: brightness(0.5) saturate(1.4);
    transform: scale(1); /* Zoom fisso richiesto */
  }
  .night-atmosphere-stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
  }
  .night-atmosphere-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(to bottom, transparent 0%, transparent 50%, rgba(8,8,20,.2) 80%, rgba(8,8,20,.45) 100%);
    pointer-events: none;
  }

  /* ═══ HERO TEXT ═══ */
  .hero-content {
    position: relative;
    z-index: 10;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding-left: 6%;
    padding-right: 6%;
  }

  .hero-sub {
    color: rgba(26,26,26,.65);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: .35em;
    text-transform: uppercase;
    margin-bottom: 22px;
    opacity: 0;
    transform: translateY(20px);
    animation: txtIn .9s ease .3s forwards;
  }
  .hero-gradient {
    background: none;
    -webkit-text-fill-color: currentColor;
    filter: none;
  }

  .hero-name {
    color: #1a1a1a;
    font-family: "Playfair Display", serif;
    font-size: clamp(52px, 8vw, 110px);
    font-weight: 400;
    line-height: .95;
    letter-spacing: -0.04em;
    margin-bottom: 28px;
    opacity: 0;
    transform: translateY(30px);
    animation: txtIn 1s ease .5s forwards;
    text-shadow: 0 2px 12px rgba(255,255,255,.35);
  }

  .hero-tag {
    color: rgba(26,26,26,.85);
    font-size: clamp(16px, 2vw, 22px);
    font-weight: 300;
    line-height: 1.6;
    max-width: 520px;
    opacity: 0;
    transform: translateY(20px);
    animation: txtIn .9s ease .7s forwards;
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 40px;
    opacity: 0;
    animation: txtIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) 1.1s forwards;
  }

  @keyframes txtIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══ SCROLL INDICATOR ═══ */
  .scroll-indicator {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
    animation: txtIn 0.8s ease 1.6s forwards;
  }
  .scroll-ind-text {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
  }
  .scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.35), transparent);
    animation: sPulse 2.2s ease-in-out infinite;
  }
  @keyframes sPulse {
    0%, 100% { opacity: 0.35; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.15); }
  }

     /* ═══ CONTENT WRAPPER ═══ */
  .content-wrapper {
    position: relative;
    z-index: 1;
  }

  /* Overlay continuo: sale per coprire Skills/Timeline, poi scende a 0 per far vedere il dark-bg */
  .content-wrapper::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      transparent 0%,             /* Trasparente all'inizio (subito dopo l'hero) */
      rgba(8, 8, 20, 0.45) 30%,  /* Si fa scuro per le Skills */
      rgba(8, 8, 20, 0.5) 45%,   /* Massima copertura per la Timeline */
      rgba(8, 8, 20, 0.35) 65%,  /* Inizia a diradarsi sul Tech Stack */
      transparent 100%           /* Completamente sparito in fondo alla pagina */
    );
  }


  /* ═══════════════════════════════════════════
     SKILLS SECTION
     ═══════════════════════════════════════════ */
  .skills-section {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    margin-top: -100vh;
    padding: calc(6rem + 100vh) 1.5rem 6rem;
    background: transparent;
  }


  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .skill-card {
    position: relative;
    overflow: hidden;
    background: rgba(8,8,20,0.45);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 18px;
    padding: 1.5rem;
    transition: transform 0.4s var(--ease-out-expo), border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .skill-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255,255,255,0.12);
    box-shadow: 0 0 20px rgba(0,212,255,0.06), 0 12px 40px rgba(0,0,0,0.3);
  }
  .skill-icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(255,255,255,0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  .skill-card:hover .skill-icon-wrap {
    background: rgba(0,212,255,0.12);
    box-shadow: 0 0 16px rgba(0,212,255,0.1);
  }
  .skill-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: #ffffff;
    margin: 0 0 0.4rem;
    letter-spacing: -0.01em;
  }
  .skill-desc {
    font-size: 0.8rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.4);
    margin: 0;
  }

  /* ═══ HORIZONTAL TIMELINE ═══ */
  .timeline-h {
    position: relative;
    padding-top: 32px;
  }
  .tl-line {
    position: absolute;
    top: 39px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.08) 15%, rgba(0,212,255,0.2) 50%, rgba(255,255,255,0.08) 85%, transparent);
  }
  .tl-track {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    position: relative;
  }
  .tl-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .tl-dot-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    position: relative;
    z-index: 2;
  }
  .tl-dot {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: 3px solid #0a0618;
    flex-shrink: 0;
    transition: all 0.4s ease;
  }
  .tl-dot-active {
    background: #00d4ff;
    box-shadow: 0 0 14px rgba(0, 212, 255, 0.5), 0 0 30px rgba(0, 212, 255, 0.15);
  }
  .tl-item:hover .tl-dot:not(.tl-dot-active) {
    background: rgba(0, 212, 255, 0.5);
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
  }
  .tl-anno {
    font-size: 12px;
    font-weight: 500;
    color: rgba(0, 212, 255, 0.65);
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .tl-card {
    width: 100%;
    padding: 24px;
    position: relative;
  }
  .tl-badge {
    position: absolute;
    top: -8px;
    right: 20px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 8px;
    background: rgba(0, 212, 255, 0.12);
    color: #00d4ff;
    border: 1px solid rgba(0, 212, 255, 0.18);
  }

  /* ═══ FIX: Solo scroll orizzontale su Mobile ═══ */
  @media (max-width: 768px) {
    
    /* Il contenitore esterno nasconde lo spazio vuoto ai lati */
    .timeline-h {
      overflow: hidden;
    }

    /* La traccia diventa un carosello scorrevole */
    .tl-track {
      display: flex;
      gap: 1.5rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory; /* Effetto magnete allo scroll */
      -webkit-overflow-scrolling: touch; /* Fluidità iOS */
      padding-bottom: 1.5rem;
      padding-left: 1.5rem; /* Margine sinistro per non attaccarsi al bordo */
      padding-right: 1.5rem;

      /* Nasconde la barra di scorrimento ma lascia scorrere col dito */
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .tl-track::-webkit-scrollbar {
      display: none;
    }

    /* Ogni card mantiene la sua larghezza e non si restringe */
    .tl-item {
      flex: 0 0 280px; /* Larghezza fissa su mobile */
      scroll-snap-align: start;
    }
    
  }

  /* --- CARD --- */
  .timeline-card {
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    width: 100%;
    max-width: 380px;
    transition: all 0.4s var(--ease-out-expo);
    text-align: center; /* Allineamento centrato sotto il fiore */
  }
  .timeline-card:hover {
    background: rgba(255,255,255,0.06);
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.3), 0 0 15px rgba(0, 212, 255, 0.05);
    border-color: rgba(255,255,255,0.12);
  }
  .timeline-anno {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #67e8f9;
    margin-bottom: 0.5rem;
  }
  .timeline-titolo {
    font-size: 1rem;
    font-weight: 500;
    color: #ffffff;
    margin: 0 0 0.4rem;
    letter-spacing: -0.01em;
  }
  .timeline-desc {
    font-size: 0.82rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.45);
    margin: 0;
  }
  /* ═══════════════════════════════════════════
     TECH STACK
     ═══════════════════════════════════════════ */
      .tech-section {
    position: relative;
    z-index: 2;
    padding: 5rem 1.5rem;
  }
  
  .tech-inner {
    max-width: 48rem;
    margin: 0 auto;
  }

  /* ═══════════════════════════════════════════
     CTA
     ═══════════════════════════════════════════ */
  .cta-section {
    position: relative;
    z-index: 2;
    padding: 5rem 1.5rem 7rem;
  }
  .cta-inner {
    position: relative;
    max-width: 40rem;
    margin: 0 auto;
    text-align: center;
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 24px;
    padding: 3.5rem 2rem;
    overflow: hidden;
  }
  .cta-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .cta-glow--cyan {
    width: 300px; height: 300px;
    top: -80px; right: -60px;
    background: rgba(0,212,255,0.08);
  }
  .cta-glow--purple {
    width: 250px; height: 250px;
    bottom: -60px; left: -40px;
    background: rgba(123,47,247,0.06);
  }
  .cta-title {
    position: relative;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: #ffffff;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }
  .cta-sub {
    position: relative;
    font-size: 0.95rem;
    color: rgba(255,255,255,0.45);
    margin: 0 0 2rem;
    line-height: 1.6;
  }
  .cta-buttons {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 768px) {
    .hero-content {
      padding-left: 6%;
      padding-right: 6%;
    }
    .hero-img {
      object-position: center top;
      transform: scale(1.15);
      animation: none;
      will-change: auto;
    }
    .skill-card {
      padding: 1.25rem;
    }
  }
</style>

<script>
  // ═══════════════════════════════════════════
  //  DAY → NIGHT CROSSFADE ON SCROLL
  // ═══════════════════════════════════════════

  const heroBg = document.querySelector('.hero-bg');
  const heroDay = document.querySelector('.hero-day');
  
  // RIFERIMENTI CORRETTI per l'atmosfera notte
  const nightAtmosphere = document.getElementById('nightAtmosphere');
  const nightImg = document.querySelector('.night-atmosphere-img');
  
  const starsCanvas = document.getElementById('starsCanvas');
  const scrollInd = document.getElementById('scrollInd');
  const heroC = document.getElementById('heroContent');
  const navBar = document.querySelector('.nav-bar');
  const heroButtons = document.querySelector('.hero-buttons');

  // ── Twinkling stars on canvas ──
  function initStars() {
    if (!starsCanvas) return;
    const ctx = starsCanvas.getContext('2d');
    let w, h, stars = [];

    function resize() {
      w = starsCanvas.width = window.innerWidth;
      h = starsCanvas.height = window.innerHeight;
      stars = [];
      const count = Math.floor((w * h) / 4000);
      for (let i = 0; i < count; i++) {
        stars.push({
          x: Math.random() * w,
          y: Math.random() * h,
          r: Math.random() * 1.5 + 0.3,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.02 + 0.005,
          brightness: Math.random() * 0.6 + 0.4,
        });
      }
    }

    function draw(time) {
      ctx.clearRect(0, 0, w, h);
      for (const s of stars) {
        const twinkle = (Math.sin(time * s.speed + s.phase) + 1) / 2;
        const alpha = s.brightness * twinkle;
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(200, 220, 255, ${alpha})`;
        ctx.fill();
      }
      requestAnimationFrame(draw);
    }

    resize();
    window.addEventListener('resize', resize, { passive: true });
    requestAnimationFrame(draw);
  }

  initStars();

  // ── Scroll handler ──
  let ticking = false;

  function smoothstep(edge0, edge1, x) {
    const t = Math.max(0, Math.min(1, (x - edge0) / (edge1 - edge0)));
    return t * t * (3 - 2 * t);
  }

  function onScroll() {
    if (ticking) return;
    ticking = true;

    requestAnimationFrame(() => {
      const y = window.scrollY;
      const vh = window.innerHeight;
      const progress = Math.min(y / vh, 1);
      const TRANS_START = 0.06;
      const TRANS_END = 0.42;
      const trans = smoothstep(TRANS_START, TRANS_END, progress);

      // DAY: fade out
      if (heroDay) {
        heroDay.style.opacity = String(1 - trans);
      }

      // NIGHT ATMOSPHERE: fade in (prima era skillsBg e non funzionava)
      if (nightAtmosphere) {
        nightAtmosphere.style.opacity = String(trans);
      }

      // NIGHT IMG: brighten solo, lo zoom è fisso nel CSS
      if (nightImg) {
        const bright = 0.5 + trans * 0.45;
        nightImg.style.filter = `brightness(${bright}) saturate(1.4)`;
      }

      // STARS: appear during the short transition
      if (starsCanvas) {
        starsCanvas.style.opacity = String(smoothstep(0.12, TRANS_END, progress));
      }

      // Release fixed day layer once transition completes
      if (heroBg) {
        heroBg.style.visibility = trans >= 0.99 ? 'hidden' : 'visible';
      }

      // BODY BACKGROUND: sky → dark (synced to short transition)
      const br = Math.round(159 * (1 - trans) + 8 * trans);
      const bg = Math.round(213 * (1 - trans) + 8 * trans);
      const bb = Math.round(241 * (1 - trans) + 20 * trans);
      document.body.style.background = `rgb(${br},${bg},${bb})`;

      // SCROLL INDICATOR FADE
      if (scrollInd) {
        scrollInd.style.opacity = Math.max(0, 1 - y / 180);
      }

      // HERO PARALLAX + FADE
      if (heroC) {
        heroC.style.transform = `translateY(${y * 0.28}px)`;
        heroC.style.opacity = Math.max(0, 1 - y / (vh * 0.7));

        // Text color transition
        const heroName = heroC.querySelector('.hero-name');
        const heroTag = heroC.querySelector('.hero-tag');
        const heroSub = heroC.querySelector('.hero-sub');

        if (heroName) {
          const r = Math.round(26 + (255 - 26) * progress * 0.6);
          const g = Math.round(26 + (255 - 26) * progress * 0.6);
          const b = Math.round(26 + (255 - 26) * progress * 0.65);
          heroName.style.color = `rgb(${r},${g},${b})`;
          heroName.style.textShadow = progress > 0.3
            ? `0 0 30px rgba(0,212,255,${progress * 0.15})`
            : `0 2px 12px rgba(255,255,255,.35)`;
        }

        if (heroTag) {
          const r = Math.round(26 + (255 - 26) * progress * 0.6);
          const g = Math.round(26 + (255 - 26) * progress * 0.6);
          const b = Math.round(26 + (255 - 26) * progress * 0.65);
          const alpha = 0.85 - progress * 0.15; // riduci leggermente l'opacità nella fase notte se vuoi
          heroTag.style.color = `rgba(${r},${g},${b},${alpha})`;
        }

        if (heroSub) {
          const spanEl = heroSub.querySelector('.hero-gradient');
          if (spanEl) {
            const r = Math.round(26 + (255 - 26) * progress * 0.6);
            const g = Math.round(26 + (255 - 26) * progress * 0.6);
            const b = Math.round(26 + (255 - 26) * progress * 0.65);
            const alpha = 0.65 + progress * 0.25;
            spanEl.style.color = `rgba(${r},${g},${b},${alpha})`;
          }
        }
      }
      // NAV: Cambia colore testi SOLO nella Home (transizione giorno/notte)
      // Nelle altre pagine userà i colori di default del CSS
      if (heroC && navBar) {
        // heroC esiste solo in index.astro, quindi questo blocco
        // non verrà mai eseguito in progetti.astro o contatti.astro
        
        const navProgress = smoothstep(TRANS_START, 0.35, progress);
        const navLinks = navBar.querySelectorAll('.nav-link');
        
        // Di giorno: testo scuro. Di notte: testo chiaro
        const linkColor = progress > 0.3 
          ? `rgba(255, 255, 255, ${0.6 + navProgress * 0.3})` 
          : `rgba(26, 26, 26, 0.7)`;
          
        navLinks.forEach(el => {
          el.style.color = linkColor;
        });
      }


      // HERO BUTTONS: transition text color
      if (heroButtons) {
        const btnProgress = smoothstep(TRANS_START, 0.35, progress);
        const btns = heroButtons.querySelectorAll('.btn-glass');
        btns.forEach(btn => {
          const isPrimary = btn.classList.contains('btn-glass--primary');
          if (isPrimary) {
            const txtVal = Math.round(26 + (255 - 26) * btnProgress);
            btn.style.color = `rgb(${txtVal},${txtVal},${txtVal})`;
            btn.style.borderColor = btnProgress > 0.4
              ? `rgba(0,212,255,${0.15 + btnProgress * 0.2})`
              : `rgba(255,255,255,${0.3 - btnProgress * 0.15})`;
          } else {
            const txtVal = Math.round(60 + (255 - 60) * btnProgress);
            btn.style.color = `rgb(${txtVal},${txtVal},${txtVal})`;
            btn.style.borderColor = `rgba(255,255,255,${0.2 - btnProgress * 0.08})`;
          }
        });
      }

      ticking = false;
    });
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  document.body.style.background = '#9FD5F1';
  onScroll();
</script>