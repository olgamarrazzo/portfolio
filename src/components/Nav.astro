---
const currentPath = Astro.url.pathname
const isActive = (path: string) => currentPath === path
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/[0.03] dark:bg-[rgba(10,6,24,0.3)] backdrop-blur-xl border-b border-white/[0.08] shadow-[inset_0_1px_1px_rgba(255,255,255,0.1),0_4px_30px_rgba(0,0,0,0.1)]" role="navigation" aria-label="Navigazione principale">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class:list={[
      'text-xl font-semibold tracking-tight transition-all duration-300',
      isActive('/') ? 'bg-gradient-to-r from-cyan-300 to-fuchsia-500 bg-clip-text text-transparent drop-shadow-[0_0_12px_rgba(34,211,238,0.4)]' : 'bg-gradient-to-r from-cyan-300 to-fuchsia-500 bg-clip-text text-transparent drop-shadow-[0_0_12px_rgba(34,211,238,0.25)]'
    ]} aria-label="Home — Olga Marrazzo" aria-current={isActive('/') ? 'page' : undefined}>
      OM
    </a>
    <div class="flex items-center gap-8">
      <a href="/progetti" class:list={[
        'text-[11px] font-medium tracking-[0.16em] uppercase transition-colors duration-300 relative pb-0.5',
        isActive('/progetti') ? 'text-cyan-400' : 'text-white/65 hover:text-white'
      ]} aria-current={isActive('/progetti') ? 'page' : undefined}>
        Progetti
        {isActive('/progetti') && <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-4 h-[2px] rounded-full bg-cyan-400"></span>}
      </a>
      <a href="/contatti" class:list={[
        'text-[11px] font-medium tracking-[0.16em] uppercase transition-colors duration-300 relative pb-0.5',
        isActive('/contatti') ? 'text-cyan-400' : 'text-white/65 hover:text-white'
      ]} aria-current={isActive('/contatti') ? 'page' : undefined}>
        Contatti
        {isActive('/contatti') && <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-4 h-[2px] rounded-full bg-cyan-400"></span>}
      </a>
    </div>
  </div>
</nav>