<div class="flower-container">
  <svg
    viewBox="0 0 120 120"
    class="flower"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Stelo -->
    <path
      class="stem"
      d="M60 95C60 75 60 60 60 45"
      stroke="#86A873"
      stroke-width="3"
      stroke-linecap="round"
    />

    <!-- Foglia -->
    <path
      class="leaf"
      d="M60 75C40 70 32 58 36 48C50 50 58 60 60 75Z"
      fill="#86A873"
    />

    <!-- Petali -->
    <g class="petals">
      <path
        class="petal petal-1"
        d="M60 48C42 42 38 25 52 18C63 25 65 38 60 48Z"
        fill="#F4B6C2"
      />
      <path
        class="petal petal-2"
        d="M60 48C65 30 80 22 88 34C84 46 72 50 60 48Z"
        fill="#F4B6C2"
      />
      <path
        class="petal petal-3"
        d="M60 48C48 32 52 18 64 16C75 26 70 40 60 48Z"
        fill="#F7C6D2"
      />
    </g>

    <!-- Centro (Fisso) -->
    <circle
      class="center"
      cx="60"
      cy="48"
      r="6"
      fill="#F6D58A"
    />
  </svg>
</div>

<style>
  .flower-container {
    width: 120px;
    height: 120px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    animation: sway 6s ease-in-out infinite;
    transform-origin: center bottom;
  }

  .flower {
    width: 100%;
    height: 100%;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* ── Animazione Ambientale (Vento lento) ── */
  @keyframes sway {
    0%, 100% { transform: rotate(0deg) translateY(0); }
    25% { transform: rotate(1.5deg) translateY(-2px); }
    75% { transform: rotate(-1.5deg) translateY(-4px); }
  }

  /* ── Preparazione Petali (Transizione Lenta) ── */
  .petals {
    transform-origin: 60px 48px;
  }

  .petal {
    transform-origin: 60px 48px;
    /* Aumentata da 0.8s a 1.5s per un bloom lento e naturale */
    transition: transform 1.5s cubic-bezier(0.34, 1.56, 0.64, 1), filter 1.5s ease;
  }
  
  /* Aumentati i ritardi per enfatizzare la cascata */
  .petal-1 { transition-delay: 0s; }
  .petal-2 { transition-delay: 0.2s; } 
  .petal-3 { transition-delay: 0.4s; } 

  .stem {
    transform-origin: 60px 95px;
    transition: transform 1.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .leaf {
    transform-origin: 60px 75px;
    opacity: 0.85;
    transition: transform 1.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* ── Il Centro: COMPLETAMENTE IMMOBILE ── */
  .center {
    /* Nessuna transizione, nessun filtro, nessun transform. Rimane fisso. */
  }

  /* ── HOVER: Il Bloom ── */
  .flower-container:hover .flower {
    transform: translateY(-8px) scale(1.05);
  }

  .flower-container:hover .stem {
    transform: rotate(-3deg);
  }

  .flower-container:hover .leaf {
    transform: rotate(5deg) translateY(3px);
  }

  /* I petali si aprono lentamente e si illuminano */
  .flower-container:hover .petal-1 {
    transform: rotate(-25deg) translateY(-4px);
    filter: drop-shadow(0 0 6px rgba(244, 182, 194, 0.6));
  }

  .flower-container:hover .petal-2 {
    transform: rotate(25deg) translateY(-4px);
    filter: drop-shadow(0 0 6px rgba(244, 182, 194, 0.6));
  }

  .flower-container:hover .petal-3 {
    transform: rotate(10deg) translateY(-6px);
    filter: drop-shadow(0 0 6px rgba(247, 198, 210, 0.6));
  }

  /* Rimosso l'hover del centro: ora fa da perno fermo */
</style>