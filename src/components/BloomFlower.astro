<div class="flower-container">

  <svg
    viewBox="0 0 120 120"
    class="flower"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >

    <!-- Stelo -->

    <path
      class="stem"
      d="M60 95C60 75 60 60 60 45"
      stroke="#86A873"
      stroke-width="3"
      stroke-linecap="round"
    />


    <!-- Foglia -->

    <path
      class="leaf"
      d="M60 75C40 70 32 58 36 48C50 50 58 60 60 75Z"
      fill="#86A873"
    />


    <!-- Petali -->

    <g class="petals">


      <path
        class="petal petal-1"
        d="M60 48C42 42 38 25 52 18C63 25 65 38 60 48Z"
        fill="#F4B6C2"
      />


      <path
        class="petal petal-2"
        d="M60 48C65 30 80 22 88 34C84 46 72 50 60 48Z"
        fill="#F4B6C2"
      />


      <path
        class="petal petal-3"
        d="M60 48C48 32 52 18 64 16C75 26 70 40 60 48Z"
        fill="#F7C6D2"
      />


    </g>


    <!-- Centro -->

    <circle
      class="center"
      cx="60"
      cy="48"
      r="6"
      fill="#F6D58A"
    />


  </svg>

</div>



<style>


.flower-container {

  width:120px;
  height:120px;

  display:flex;
  justify-content:center;
  align-items:center;

  position:relative;

}



.flower {

  width:100%;
  height:100%;

  transform-origin:center bottom;

  animation:
    floatFlower 5s ease-in-out infinite;

  transition:
    transform .8s cubic-bezier(.22,1,.36,1);

}



/* movimento leggero come vento */

@keyframes floatFlower {

  0%,100% {

    transform:
      translateY(0)
      rotate(0deg);

  }


  50% {

    transform:
      translateY(-4px)
      rotate(2deg);

  }

}



/* apertura petali */

.petals {

  transform-origin:
    60px 48px;

}



.petal {

  transform-origin:
    60px 48px;

  transition:
    transform .8s cubic-bezier(.22,1,.36,1);

}



/* hover */

.flower-container:hover .flower {

  transform:
    translateY(-6px)
    scale(1.08);

}



.flower-container:hover .petal-1 {

  transform:
    rotate(-18deg);

}



.flower-container:hover .petal-2 {

  transform:
    rotate(18deg);

}



.flower-container:hover .petal-3 {

  transform:
    rotate(8deg);

}



/* foglia leggermente più morbida */

.leaf {

  opacity:.85;

}



</style>